//@version=6
indicator("668 Rating Lower", "668 Rating Lower", false, precision = 3)

import TradingView/TechnicalRating/3 as TVtr

string RT1 = "MAs and Oscillators"
string RT2 = "MAs"
string RT3 = "Oscillators"
string ON  = "On"
string OFF = "Off"

var float LEVEL_STRONG = 0.5
var float LEVEL_WEAK   = 0.1

string TF_TT = "Select a timeframe that is higher than or equal to the chart's timeframe."
string MA_TT = "Weight of the MA rating when showing the total rating."
string RP_TT = "If off, higher timeframe ratings only update after the HTF bar closes."

string ratingSource = input.string(RT1, "Rating to Plot", options = [RT1, RT2, RT3])
float  maWeight     = input.int(50, "MA Weight (%)", minval = 0, maxval = 100, step = 10) / 100
string tfInput      = input.timeframe("", "Timeframe", tooltip = TF_TT)
bool   repaint      = input.string(ON, "Repainting", options = [ON, OFF], tooltip = RP_TT) == ON
color  bullColor    = input.color(#00ff00, "Bull Color")
color  bearColor    = input.color(#ff0000, "Bear Color")
color  neutralColor = input.color(#808080, "Neutral Color")

colorFromRating(float rating, color bullColor, color bearColor, color neutralColor) =>
    float absRating = math.abs(nz(rating))
    float transp    = 80.0 * (1.0 - math.min(absRating, 1.0))
    switch
        rating >  LEVEL_WEAK => color.new(bullColor, transp)
        rating < -LEVEL_WEAK => color.new(bearColor, transp)
        =>                   color.new(neutralColor, 50)

textFromRating(float rating) =>
    switch
        rating >  LEVEL_STRONG => "Strong Buy"
        rating >  LEVEL_WEAK   => "Buy"
        rating < -LEVEL_STRONG => "Strong Sell"
        rating < -LEVEL_WEAK   => "Sell"
        =>                        "Neutral"

bool htfUsed = tfInput != "" and timeframe.in_seconds(tfInput) > timeframe.in_seconds(timeframe.main_period)
int  offset  = htfUsed and not repaint ? 1 : 0
var  lookahead = htfUsed and not repaint ? barmerge.lookahead_on : barmerge.lookahead_off

[_, ratingOscChart, ratingMasChart] = TVtr.calcRatingAll()
float ratingTotChart = nz(ratingMasChart * maWeight) + nz(ratingOscChart * (1.0 - maWeight))

float ratingTot = na
float ratingOsc = na
float ratingMas = na
if tfInput == ""
    ratingTot := ratingTotChart
    ratingOsc := ratingOscChart
    ratingMas := ratingMasChart
else
    [ratingTot, ratingOsc, ratingMas] = request.security(
        syminfo.tickerid,
        tfInput,
        [ratingTotChart[offset], ratingOscChart[offset], ratingMasChart[offset]],
        lookahead = lookahead
    )

float rating = switch ratingSource
    RT2 => ratingMas
    RT3 => ratingOsc
    =>     ratingTot

color ratingColor = colorFromRating(rating, bullColor, bearColor, neutralColor)

plot(rating, "Rating", ratingColor, linewidth = 2)
plot(0.0, "Zero Line", color = color.new(#888888, 50), style = plot.style_line, linewidth = 1)
hline(0.0, "Zero", color = color.new(#888888, 60), linestyle = hline.style_dashed, linewidth = 1)
