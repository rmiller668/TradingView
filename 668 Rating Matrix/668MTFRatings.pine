//@version=6
indicator("668 MTF Ratings", "MTF Ratings", true, precision = 2)

import TradingView/TechnicalRating/3 as TVtr

// Colors
color LIME    = #00ff00
color RED     = #ff0000
color WHITE   = #ffffff
color NEUTRAL = #808080

// Threshold levels for strong and weak Buy/Sell ratings
const float LEVEL_STRONG = 0.5
const float LEVEL_WEAK   = 0.1

// Input options
string RT1 = "MAs and Oscillators"
string RT2 = "MAs"
string RT3 = "Oscillators"
string ON  = "On"
string OFF = "Off"

// Tooltips
string B_TT = "Base color for Buy and Strong Buy ratings. Intensity scales with rating strength."
string S_TT = "Base color for Sell and Strong Sell ratings. Intensity scales with rating strength."
string RP_TT = (
    "If On, higher-timeframe ratings update during an open realtime bar. "
    + "If Off, higher-timeframe ratings update only after a realtime bar closes."
)
string MA_TT = (
    "Specifies the percentage weight of the MA rating for the total rating. The percentage weight of the oscillator "
    + "rating is 100 - MA weight."
)
string TS_TT = "Specifies the height and width of each display cell as a percentage of the pane's space."

// Inputs
string GRP1           = "Display"
string yPosInput      = input.string("top",    "Position",      inline = "11", group = GRP1, options = ["top", "middle", "bottom"])
string xPosInput      = input.string("right",  "",              inline = "11", group = GRP1, options = ["left", "center", "right"])
int    heightInput    = input.int(3,           "Height",        inline = "12", group = GRP1, minval = 1, maxval = 100)
int    widthInput     = input.int(10,          "Width",         inline = "12", group = GRP1, minval = 1, maxval = 100, tooltip = TS_TT)
color  textColorInput = input.color(WHITE,     "Text",          inline = "13", group = GRP1)
string textSizeInput  = input.string("normal", "Size",          inline = "13", group = GRP1, options = ["tiny", "small", "normal", "large", "huge", "auto"])
color  bullColorInput = input.color(LIME,      "Bull color",    inline = "14", group = GRP1, tooltip = B_TT)
color  bearColorInput = input.color(RED,       "Bear color",    inline = "15", group = GRP1, tooltip = S_TT)
color  neutColorInput = input.color(NEUTRAL,   "Neutral color", inline = "16", group = GRP1)

string GRP2       = "Calculations"
bool   repaint    = input.string(ON,  "Repainting",        group = GRP2, options = [ON, OFF], tooltip = RP_TT) == ON
string ratingMode = input.string(RT1, "Rating uses",       group = GRP2, options = [RT2, RT3, RT1])
float  maWeight   = input.int(50,     "Weight of MAs (%)", group = GRP2, tooltip = MA_TT, minval = 0, maxval = 100, step = 10) / 100

// Functions
colorFromRating(float rating, color bullColor, color bearColor, color neutralColor) =>
    float absRating = math.abs(nz(rating))
    float transp    = 80.0 * (1.0 - math.min(absRating, 1.0))
    switch
        rating >  LEVEL_WEAK => color.new(bullColor, transp)
        rating < -LEVEL_WEAK => color.new(bearColor, transp)
        =>                      color.new(neutralColor, 50)

textFromRating(float rating) =>
    switch
        rating >  LEVEL_STRONG => "Strong Buy"
        rating >  LEVEL_WEAK   => "Buy"
        rating < -LEVEL_STRONG => "Strong Sell"
        rating < -LEVEL_WEAK   => "Sell"
        =>                        "Neutral"

calcRating() =>
    [_, ratingOsc, ratingMas] = TVtr.calcRatingAll()
    float ratingTot = nz(ratingMas * maWeight) + nz(ratingOsc * (1.0 - maWeight))
    switch ratingMode
        RT2 => ratingMas
        RT3 => ratingOsc
        =>    ratingTot

getRatingForTF(simple string tf) =>
    simple bool htfUsed = timeframe.in_seconds(tf) > timeframe.in_seconds(timeframe.main_period)
    simple int offset = htfUsed and not repaint ? 1 : 0
    simple barmerge_lookahead lookahead = htfUsed and not repaint ? barmerge.lookahead_on : barmerge.lookahead_off
    request.security(syminfo.tickerid, tf, calcRating()[offset], lookahead = lookahead)

setRatingCell(table display, int col, string label, float rating) =>
    string ratingText = textFromRating(rating)
    string cellText = str.format("{0}\n{1}", label, ratingText)
    table.cell(
         display, col, 0, cellText,
         width = widthInput, height = heightInput,
         text_color = textColorInput,
         bgcolor = colorFromRating(rating, bullColorInput, bearColorInput, neutColorInput),
         text_size = textSizeInput,
         tooltip = str.format("{0}: {1} ({2, number, 0.0000})", label, ratingText, rating)
     )

// Calculations
float dailyRating     = getRatingForTF("D")
float weeklyRating    = getRatingForTF("W")
float monthlyRating   = getRatingForTF("M")
float quarterlyRating = getRatingForTF("3M")

// Display
var table display = table.new(yPosInput + "_" + xPosInput, 4, 1)

if barstate.islast
    // Columns are arranged so the table reads right-to-left as Daily, Weekly, Monthly, Quarterly.
    setRatingCell(display, 0, "Quarterly", quarterlyRating)
    setRatingCell(display, 1, "Monthly",   monthlyRating)
    setRatingCell(display, 2, "Weekly",    weeklyRating)
    setRatingCell(display, 3, "Daily",     dailyRating)

// Plot rating values in the data window.
plot(dailyRating,     "Daily",     colorFromRating(dailyRating,     bullColorInput, bearColorInput, neutColorInput), display = display.data_window, editable = false)
plot(weeklyRating,    "Weekly",    colorFromRating(weeklyRating,    bullColorInput, bearColorInput, neutColorInput), display = display.data_window, editable = false)
plot(monthlyRating,   "Monthly",   colorFromRating(monthlyRating,   bullColorInput, bearColorInput, neutColorInput), display = display.data_window, editable = false)
plot(quarterlyRating, "Quarterly", colorFromRating(quarterlyRating, bullColorInput, bearColorInput, neutColorInput), display = display.data_window, editable = false)
