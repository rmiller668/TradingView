//@version=6
indicator("668 RCG Overlay", "RCG Overlay", overlay=true)
// ── Inputs
basisPeriod       = input.int(12, "Basis Period", minval = 1, tooltip = "Chart bars in the sliding return window used to measure current compensation. For example, 12 bars means 12 days on a daily chart or 12 weeks on a weekly chart.")
environmentPeriod = input.int(12, "Compensation Environment Period", minval = 1, tooltip = "Chart bars used by the exponential moving average of Basis Compensation. Recent outcomes receive greater weight, allowing the environment to respond sooner to change.")
structuralPeriod  = input.int(60, "Structural Environment Period", minval = 1, tooltip = "Chart bars included in the simple moving average of Basis Compensation. Each outcome receives equal weight to create a slower structural baseline.")

// Overlay Colors
aboveColor   = input.color(color(#90bff9), "Above Zero Color")
belowColor   = input.color(color(#ffffff), "Below Zero Color")
neutralColor = input.color(color(#4a4a4a), "Neutral Color")
lineWidth    = input.int(2, "Overlay Line Width", minval=1, maxval=5)

// Compensation Environment Label
showEnvironmentLabel = input.bool(true, "Show Compensation Environment")
environmentTextSizeInput = input.string("Normal", "Environment Text Size", options=["Tiny", "Small", "Normal", "Large", "Huge"])

// Current Price Line
showCurrentPriceLine = input.bool(true, "Show Current Price Line")
currentLineStyleInput = input.string("Dotted", "Current Price Line Style", options=["Solid", "Dashed", "Dotted"])
currentLineWidth = input.int(1, "Current Price Line Width", minval=1, maxval=5)

// Window Options
showBasisWindow = input.bool(false, "Show Basis Window")
showEnvironmentWindow = input.bool(false, "Show Environment Window")

basisLineColor = input.color(color.rgb(184, 184, 184), "Basis Window Line Color")
environmentLineColor = input.color(color.rgb(16, 172, 175), "Environment Window Line Color")

// ── RCG Calculation
basePrice = close[basisPeriod]
basisRoR       = na(basePrice) ? na : ((close - basePrice) / basePrice) * 100
environmentRoR = ta.ema(basisRoR, environmentPeriod)
structuralRoR  = ta.sma(basisRoR, structuralPeriod)
compDifferential = basisRoR - environmentRoR

// ── Environment Display Window
// This finite span scales the color gradient and draws the optional
// window. The EMA itself retains exponentially decreasing older data.
environmentLookback = basisPeriod + environmentPeriod - 1

highestPositive = ta.highest(math.max(environmentRoR, 0), environmentLookback)
lowestNegative  = ta.lowest(math.min(environmentRoR, 0), environmentLookback)

positiveSpan = math.max(highestPositive, 0.0001)
negativeSpan = math.max(math.abs(lowestNegative), 0.0001)

// ── Color Function
getCompColor(value) =>
    if na(value)
        neutralColor
    else if value > 0
        strength = math.min(value / positiveSpan, 1)
        color.from_gradient(strength, 0, 1, neutralColor, aboveColor)
    else if value < 0
        strength = math.min(math.abs(value) / negativeSpan, 1)
        color.from_gradient(strength, 0, 1, neutralColor, belowColor)
    else
        neutralColor

getLineStyle(styleInput) =>
    switch styleInput
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted

getTextSize(sizeInput) =>
    switch sizeInput
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge

overlayColor = getCompColor(environmentRoR)

// ── Compensation Environment Language
stateText =
     na(environmentRoR) ? "Unavailable" :
     environmentRoR > 0 ? "Positive" :
     environmentRoR < 0 ? "Negative" :
     "Transitional"

directionText =
     na(basisRoR) or na(environmentRoR) ? "" :
     basisRoR > environmentRoR ? "Improving" :
     basisRoR < environmentRoR ? "Deteriorating" :
     "Stable"

structuralText =
     na(environmentRoR) or na(structuralRoR) ? "" :
     environmentRoR > structuralRoR ? " | Above Structure" :
     environmentRoR < structuralRoR ? " | Below Structure" :
     " | At Structure"

environmentText =
     stateText == "Unavailable" ? "Compensation Environment: Unavailable" :
     "Compensation Environment: " + stateText + " and " + directionText +
     " (" + str.tostring(compDifferential, "#.#") + "%)" + structuralText

// ── Compensation Environment Display
var table envTable = table.new(position.bottom_right, 1, 1)

if barstate.islast and showEnvironmentLabel
    table.cell(
         envTable,
         0,
         0,
         environmentText,
         text_color = overlayColor,
         text_size = getTextSize(environmentTextSizeInput),
         bgcolor = color.new(color.black, 100)
    )

if barstate.islast and not showEnvironmentLabel
    table.clear(envTable, 0, 0)

// ── Compensation-Colored Price Overlay
plot(
     close,
     title = "Compensation-Colored Price",
     color = overlayColor,
     linewidth = lineWidth
)

// ── Drawing Objects
var line basisLine = na
var line environmentLine = na
var line currentPriceLine = na

// ── Draw Compensation Windows And Current Price Line
if bar_index >= environmentLookback

    line.delete(basisLine)
    line.delete(environmentLine)
    line.delete(currentPriceLine)

    if showBasisWindow
        basisLine := line.new(
             x1 = bar_index - basisPeriod,
             y1 = close[basisPeriod],
             x2 = bar_index,
             y2 = close,
             xloc = xloc.bar_index,
             extend = extend.none,
             color = basisLineColor,
             width = 1,
             style = line.style_solid
        )

    if showEnvironmentWindow
        environmentLine := line.new(
             x1 = bar_index - environmentLookback,
             y1 = close[environmentLookback],
             x2 = bar_index,
             y2 = close,
             xloc = xloc.bar_index,
             extend = extend.none,
             color = environmentLineColor,
             width = 1,
             style = line.style_solid
        )

    if showCurrentPriceLine
        currentPriceLine := line.new(
            x1 = bar_index - 1,
            y1 = close,
            x2 = bar_index,
            y2 = close,
            xloc = xloc.bar_index,
            extend = extend.both,
            color = overlayColor,
            width = currentLineWidth,
            style = getLineStyle(currentLineStyleInput)
        )
