//@version=6
indicator("RCG Histogram", "668 RCG Hist", overlay = false)

// RCG Histogram
//
// This view centers the Compensation Environment against the
// Structural Compensation Environment.
//
// The zero line represents the Structural Compensation baseline.
// The histogram measures the spread between the short-term
// Compensation Environment and the Structural Environment.
//
// Above zero = Compensation Environment is stronger than structure.
// Below zero = Compensation Environment is weaker than structure.

// Inputs
basisPeriod        = input.int(12, "Basis Period", minval = 1, tooltip = "Sliding lookback window used to measure current compensation.")
environmentPeriod  = input.int(12, "Compensation Environment Period", minval = 1, tooltip = "Number of recent Basis measurements averaged to reveal the current compensation environment.")
structuralPeriod   = input.int(60, "Structural Environment Period", minval = 1, tooltip = "Number of recent Basis measurements averaged to reveal the structural compensation environment.")

// Risk Compensation Calculation
basePrice = close[basisPeriod]

basisRoR       = na(basePrice) ? na : ((close - basePrice) / basePrice) * 100
environmentRoR = ta.sma(basisRoR, environmentPeriod)
structuralRoR  = ta.sma(basisRoR, structuralPeriod)

environmentSpread = environmentRoR - structuralRoR

// Plots
hline(0, "Structural Compensation Environment", linewidth = 1, linestyle = hline.style_solid, color = color(#636363))

histogramColor = environmentSpread >= 0 ? color.new(#90bff9, 0) : color.new(#d96c75, 0)
plot(environmentSpread, title = "Compensation Environment vs Structural Environment (%)", style = plot.style_columns, linewidth = 2, color = histogramColor)
