//@version=6
indicator("Rate of Return (%)", overlay = false)

// ── Inputs ─────────────────────────────────────────────
basis = input.int(12, "Basis Period", minval = 1,
     tooltip = "Lookback used to measure rolling basis risk rate of return.")

fastPeriod = input.int(3, "Short-term Period", minval = 1,
     tooltip = "Short-term return regime (immediate risk compensation).")

slowPeriod = input.int(12, "Long-term Period", minval = 1,
     tooltip = "Intermediate return regime (sustained risk compensation).")

statusPosition = input.string(
     "top_right",
     "Status Box Position",
     options = ["top_left", "top_right", "bottom_left", "bottom_right"]
)

// ── Status Colors (Inputs) ─────────────────────────────
upColor = input.color(color.rgb(34, 171, 148), "Advancing Color")
downColor = input.color(color.rgb(242, 54, 69), "Declining Color")
neutralColor = input.color(color.new(color.gray, 80), "Flat Color")
textColor = input.color(color.white, "Text Color")

// ── Rate of Return Calculation ─────────────────────────
basePrice   = close[basis]
performance = na(basePrice) ? na : ((close - basePrice) / basePrice) * 100

realRoR = performance
fastRoR = ta.sma(performance, fastPeriod)
slowRoR = ta.sma(performance, slowPeriod)
rorSpread = fastRoR - slowRoR

// ── Direction Logic ────────────────────────────────────
realDir =
     realRoR > 1 ?  1 :
     realRoR < 0 ? -1 : 0

fastDir =
     fastRoR > 1 ?  1 :
     fastRoR < 0 ? -1 : 0

slowDir =
     slowRoR > 1 ?  1 :
     slowRoR < 0 ? -1 : 0

// ── Cell Colors ────────────────────────────────────────
realColor =
     realDir ==  1 ? upColor :
     realDir == -1 ? downColor :
     neutralColor
     
fastColor =
     fastDir ==  1 ? upColor :
     fastDir == -1 ? downColor :
     neutralColor

slowColor =
     slowDir ==  1 ? upColor :
     slowDir == -1 ? downColor :
     neutralColor

formatPercent(x) =>
    na(x) ? "—" : str.format("{0,number,#0.0}%", x) 

// ── Plot ───────────────────────────────────────────────
plot(performance, title = "Basis RoR (%)", linewidth = 1, color = color.gray)
plot(fastRoR, title = "Short-term RoR (%)", linewidth = 2, color = color.rgb(16, 172, 175))
plot(slowRoR, title = "Long-term RoR (%)", linewidth = 2, color = color.white)
// ── Histogram (Fast − Slow) ────────────────────────────
plot(
    rorSpread,
    title = "RoR Regime Spread",
    style = plot.style_histogram,
    color = rorSpread > 0 ? upColor : rorSpread < 0 ? downColor : neutralColor,
    linewidth = 2
)

// ── Zero Line ──────────────────────────────────────────
hline(0, "Zero Line")

// ── Status Table (FAST | SLOW) ─────────────────────────
var table statusTable = table.new(
     statusPosition == "top_left" ? position.top_left :
     statusPosition == "top_right" ? position.top_right :
     statusPosition == "bottom_left" ? position.bottom_left :
     position.bottom_right,
     2, 2, border_width = 1
)

// ── Orientation Hint ───────────────────────────────────
var table hintTable = table.new(
    position.bottom_center,
    1, 1,
    frame_color = color.new(color.gray, 80),
    frame_width = 1
)

if barstate.islast
    table.merge_cells(statusTable, 0, 0, 1, 0)
    // FAST cell
    table.cell(
        statusTable,
        0, 0,
        "BASIS (" + formatPercent(performance) + ")",
        text_color = textColor,
        bgcolor = realColor,
        text_size = size.small
    )

    // FAST cell
    table.cell(
        statusTable,
        0, 1,
        "FAST (" + formatPercent(fastRoR) + ")",
        text_color = textColor,
        bgcolor = fastColor,
        text_size = size.small,
        width = 5
    )

    // SLOW cell
    table.cell(
        statusTable,
        1, 1,
        "SLOW (" + formatPercent(slowRoR) + ")",
        text_color = textColor,
        bgcolor = slowColor,
        text_size = size.small,
        width = 5
    )

    // Hint
    table.cell(
        hintTable,
        0, 0,
        "How is the market currently compensating risk exposure, and is that compensation improving or deteriorating across regimes?",
        text_color = color.gray,
        bgcolor = color.new(color.black, 90),
        text_size = size.small,
        text_halign = text.align_center,
        width = 100
    )
